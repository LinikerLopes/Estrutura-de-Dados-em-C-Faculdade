#include <iostream>


void exemplo_um(void){
	int a = 10, b = 20, c;
	int *p, *q;
	
	p = &a;
	q = &b;
	
	c = *p + *q;
	
	std::cout << "Exemplo 1: ponteir simples:" << std:: endl;
	std::cout << "a:  " << a << " b: " << b << " c: " << c << std::endl;
	std:: cout << "*p: " << *p << " *q: " << *q << std::endl;
	std:: cout << " c = *p + *q:  " << c << std::endl;
}

void exemplo_dois(void){
	int a = 15, b = 25, c;
	int *p;
	int **r;
	
	p = &a;
	r = &p;
	
	c = **r + b;
	
	std::cout << "Exemplo 2: ponteir para ponteiro:" << std:: endl;
	std::cout << "a:  " << a << " b: " << b << std::endl;
	std:: cout << "*p: " << *p << " **r: " << **r << std::endl;
	std:: cout << " c = **r + b:  " << c << std::endl;
	
}

int main(void){
	exemplo_um();
	exemplo_dois();
	return 0;
}
